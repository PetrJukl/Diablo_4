<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Diablo4.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid">
        <Grid.Background>
            <ImageBrush ImageSource="/Assets/diablo.jpeg" Stretch="UniformToFill"/>
        </Grid.Background>

        <TextBlock
            x:Name="messageLabel"
            Text="{x:Bind ViewModel.MessageText, Mode=OneWay}"
            FontSize="45"
            Foreground="White"
            TextAlignment="Center"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Width="888"
            Height="257"
            TextWrapping="Wrap"
            Margin="380,340,0,0"/>

        <TextBlock
            x:Name="weekDuration"
            Text="{x:Bind ViewModel.WeekDurationText, Mode=OneWay}"
            FontSize="29"
            FontWeight="Bold"
            Foreground="White"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="8,360,0,0"/>

        <TextBlock
            x:Name="lastWeekDuration"
            Text="{x:Bind ViewModel.LastWeekDurationText, Mode=OneWay}"
            FontSize="29"
            FontStyle="Italic"
            Foreground="White"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="8,450,0,0"/>
    </Grid>
</Window>


