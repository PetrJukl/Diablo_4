<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Diablo4.WinUI.Views.WeekendMotivationDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid">
        <!-- Pozadí: čtvercový obrázek ve čtvercovém okně = žádné ořezání -->
        <Grid.Background>
            <ImageBrush ImageSource="ms-appx:///Assets/gaming-support.jpg" Stretch="UniformToFill"/>
        </Grid.Background>

        <!-- Drag oblast pro vlastní title bar -->
        <Grid x:Name="AppTitleBar" VerticalAlignment="Top" Height="32"/>

        <!-- Gradient fade pro čitelnost textu -->
        <Border VerticalAlignment="Bottom" Height="220" IsHitTestVisible="False">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="Transparent" Offset="0"/>
                    <GradientStop Color="#BB000000" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Motivační text přes obrázek -->
        <TextBlock
            x:Name="WeekLabel1"
            Text="Těch 10 hodin přeci zvládneme."
            Margin="20,0,20,78"
            VerticalAlignment="Bottom"
            HorizontalAlignment="Left"
            FontSize="40"
            FontWeight="Black"
            Foreground="#CC00CC"
            TextWrapping="WrapWholeWords"/>

        <!-- Moderní spodní panel s dark theme -->
        <Border
            VerticalAlignment="Bottom"
            Height="66"
            CornerRadius="16,16,0,0"
            Padding="20,0"
            RequestedTheme="Dark"
            Background="#CC1E3C7A">
            <StackPanel
                Orientation="Horizontal"
                VerticalAlignment="Center"
                Spacing="12">
                <TextBlock
                    Text="Chceš si zapařit?"
                    VerticalAlignment="Center"
                    FontSize="15"
                    FontWeight="SemiBold"
                    Foreground="#DDE0F0"/>
                <ComboBox
                    x:Name="GamesComboBox"
                    MinWidth="170"
                    VerticalAlignment="Center">
                    <ComboBox.Resources>
                        <SolidColorBrush x:Key="ComboBoxBackground" Color="#162E68"/>
                        <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="#1E3C7A"/>
                        <SolidColorBrush x:Key="ComboBoxBackgroundPressed" Color="#112255"/>
                        <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="#162E68"/>
                        <SolidColorBrush x:Key="ComboBoxDropDownBorderBrush" Color="#1E3C7A"/>
                        <SolidColorBrush x:Key="ComboBoxItemBackground" Color="Transparent"/>
                        <SolidColorBrush x:Key="ComboBoxItemBackgroundPointerOver" Color="#1E3C7A"/>
                        <SolidColorBrush x:Key="ComboBoxItemBackgroundSelected" Color="#243F8A"/>
                        <SolidColorBrush x:Key="ComboBoxItemBackgroundSelectedPointerOver" Color="#2A4A96"/>
                    </ComboBox.Resources>
                </ComboBox>
                <Button
                    x:Name="AnoButton"
                    Content="Ano"
                    Width="88"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="AnoButton_Click"/>
                <Button
                    x:Name="NeButton"
                    Content="Ne"
                    Width="66"
                    Click="NeButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
