<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="Diablo4.WinUI.Views.WeekendMotivationDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Weekend Motivace"
    PrimaryButtonText="Ano"
    CloseButtonText="Ne"
    DefaultButton="Primary"
    PrimaryButtonClick="ContentDialog_PrimaryButtonClick">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Assets/gaming-support.jpg" Stretch="UniformToFill"/>
        </Grid.Background>

        <StackPanel Spacing="20" Padding="20" Background="#CC000000">
            <TextBlock 
                x:Name="WeekLabel1"
                Text="Těch 10 hodin přeci zvládneme."
                FontSize="38"
                FontWeight="Black"
                Foreground="#C000C0"
                TextWrapping="Wrap"
                HorizontalAlignment="Center"/>

            <TextBlock 
                x:Name="StartGameLabel"
                Text="Chceš si zapařit?"
                FontSize="27"
                FontWeight="Bold"
                Foreground="Black"
                HorizontalAlignment="Center"
                Margin="0,20,0,0"/>

            <ComboBox 
                x:Name="GamesComboBox"
                HorizontalAlignment="Center"
                MinWidth="250"/>
        </StackPanel>
    </Grid>
</ContentDialog>
